# Copy this file to .env and fill in your values.
# The setup script does this automatically.

# Network scanning:
#   auto             -> detect the active adapter/subnet at startup
#   192.168.1.0/24  -> force a specific subnet
#   192.168.1.1-50  -> force a specific IP range
SCAN_TARGET=auto

# Where the SQLite database file will be stored
DATABASE_URL=sqlite:///./data/netmon.db

# Port the web app runs on
APP_PORT=8000

# Bind address for the dashboard. Default 0.0.0.0 is reachable from any
# device on your LAN (use the LAN IP, e.g. http://192.168.1.64:8000).
# Set to 127.0.0.1 to lock the dashboard to this machine only — note
# that the phone can still receive ntfy notifications either way, since
# those go through the ntfy server, not the NetMon dashboard.
# BIND_HOST=0.0.0.0

# Dashboard login. Run `python tools/set_password.py --write` or
# `.\tools\setup.ps1` to fill these in.
# APP_USERNAME=admin
# APP_PASSWORD_HASH=

# AI provider. `ollama` is local-only. Use `chain` to try configured cloud
# providers first and fall back to Ollama.
AI_PROVIDER=ollama
AI_FAST_MODEL=qwen2.5:3b
# AI_DEEP_MODEL=qwen2.5:7b
OLLAMA_HOST=http://localhost:11434

# Optional cloud AI keys. Leave blank for a local-only setup.
# Prefer Windows user/system environment variables for real keys. If you use a
# local .env file, keep it private and never commit it.
# GROQ_API_KEY=
# CEREBRAS_API_KEY=
# SAMBANOVA_API_KEY=
# OPENROUTER_API_KEY=
# GEMINI_API_KEY=
# ANTHROPIC_API_KEY=

# Notification secrets (optional) — kept out of the DB so they don't sit
# in plain text on disk. When set, the Settings UI shows the field as
# read-only and the value is loaded from here on every notification.
# NTFY_PASS=
# SMTP_PASS=

# Optional self-hosted ntfy server. If ntfy is installed and these files exist,
# launch.py can start it with the tray app.
# NTFY_EXE=C:\ntfy\ntfy.exe
# NTFY_CONFIG=C:\ntfy\server.yml
# NTFY_URL=http://localhost:2586
